# Files excluded from the Vercel deployment so they are NOT served publicly.
# The live app loads the bundled .min outputs (aurum.min.js, portfolios.min.js,
# components/aurum/worker.min.js, style.min.css) and fetches data/*.json — those
# are kept. Raw client source + offline tooling below are excluded.
# (package.json is needed by Vercel at build time and already 404s for static
#  requests, so it is intentionally not listed.)

# Offline build + CI pipeline (optimizer build, web build, tests, verifiers).
scripts/
.github/

# Raw client source — the site loads the bundled/minified versions instead.
/aurum.js
/portfolios.js
/style.css
components/aurum/state.js
components/aurum/ingestion.js
components/aurum/renderer.js
components/aurum/engine.js
components/aurum/exporter.js
components/aurum/escape.js
components/aurum/worker.js

# Internal docs.
*.md
*.docx
